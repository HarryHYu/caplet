# Database (PostgreSQL). Omit to use local SQLite fallback in dev.
DATABASE_URL=postgres://username:password@localhost:5432/caplet_dev

# Required in production
JWT_SECRET=your-super-secret-jwt-key-change-in-production
ADMIN_BOOTSTRAP_TOKEN=your-bootstrap-token-for-admin-setup

# Google OAuth (same client ID as frontend VITE_GOOGLE_CLIENT_ID)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Server
PORT=5002
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
TRUST_PROXY_HOPS=1

# Operational safety and audit retention
RATE_LIMIT_KEY_SALT=replace-with-a-long-random-value
AI_USER_QUOTA_WINDOW_MS=900000
AI_USER_QUOTA_UNITS=40
AI_USER_MAX_CONCURRENT=2
AI_CIRCUIT_WINDOW_MS=300000
AI_CIRCUIT_MIN_REQUESTS=10
AI_CIRCUIT_FAILURE_RATE=0.6
AI_CIRCUIT_OPEN_MS=60000
# Optional planning estimate; leave unset until finance validates a blended unit cost.
AI_ESTIMATED_COST_USD_PER_UNIT=
AI_MONTHLY_BUDGET_USD=
OBSERVABILITY_WINDOW_MINUTES=15
OBSERVABILITY_MAX_EVENTS=5000
PRODUCT_EVENT_RETENTION_DAYS=365
GUARDIAN_REQUEST_RETENTION_DAYS=90
DATA_RETENTION_SWEEP_HOURS=6
BACKUP_MAX_AGE_HOURS=26
OPS_SERVICE_TOKEN=replace-with-at-least-32-random-characters
OPS_ALERT_WEBHOOK_URL=
OPS_ALERT_RETRY_BASE_MS=60000
OPS_MONITOR_INTERVAL_MS=60000
AI_WORKSPACE_HISTORY_DAYS=90
RESEND_API_KEY=
GUARDIAN_CONSENT_FROM_EMAIL=Caplet <guardian-consent@caplet.org>
MODERATION_NOTIFICATION_WEBHOOK_URL=
MODERATION_NOTIFICATION_EMAIL=
MODERATION_NOTIFICATION_FROM_EMAIL=Caplet Safety <safety@caplet.org>
MODERATION_NOTIFICATION_RETRY_BASE_MS=60000
MODERATION_NOTIFICATION_SWEEP_MS=60000

# Money pilot — configure from a reviewed ABS release before enabling
# money.mode.pilot in a shared or production environment.
MONEY_CPI_VALUE=
MONEY_CPI_OBSERVATION_PERIOD=
MONEY_CPI_PUBLISHED_AT=
MONEY_CPI_NEXT_RELEASE_AT=
MONEY_CPI_DATA_VERSION=

# OpenAI — kept for future AI features (aiService.js)
OPENAI_API_KEY=

# AWS S3 — image uploads (presigned PUT). See docs/aws-s3-setup.md
AWS_REGION=ap-southeast-2
AWS_S3_BUCKET=your-bucket-name
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Optional: override public URL base (e.g. CloudFront)
# S3_PUBLIC_BASE_URL=https://d1234567890.cloudfront.net

# Consumer Data Right (Financial Twin). CDR_MODE=mock (default) uses the
# in-repo synthetic provider — no credentials needed. CDR_MODE=real and the
# CDR_CLIENT_* credentials are REFUSED at boot unless CDR_ACCREDITED=true,
# which must only be set once CDR accreditation has actually been granted
# (a regulatory process — see backend/services/cdr/index.js).
# CDR_MODE=mock
# CDR_ACCREDITED=
# CDR_CLIENT_ID=
# CDR_CLIENT_SECRET=
# CDR_PRIVATE_KEY_PATH=
