# Backend API URL. Must include the /api suffix.
# Leave unset in dev to use the local backend (http://localhost:5002/api),
# or set it to the production backend to log into your real account.
VITE_API_BASE_URL=https://caplet-production.up.railway.app/api

# Google Sign-In: create an OAuth 2.0 Client ID (Web application) in Google Cloud Console.
# Authorized JavaScript origins: http://localhost:5173 (Vite dev), your production site URL.
# Authorized redirect URIs: not required for the ID-token flow used here, but you can add the site origin.
# Use the same Client ID string for both variables below.
VITE_GOOGLE_CLIENT_ID=392719147746-htpi2dg4gr5sn76sef30objnc7svj7he.apps.googleusercontent.com
# Backend (Railway / local): same value as GOOGLE_CLIENT_ID

# Google Maps Embed API key — used for the Maps embed builder in the lesson editor.
# Create one at console.cloud.google.com → APIs & Services → Credentials → API key.
# Enable: Maps Embed API. Restrict the key to your domain in production.
VITE_GOOGLE_MAPS_KEY=

# Desmos API key — used for embedded graphing/scientific calculators.
# The demo key below works for development. For production, email info@desmos.com
# to obtain your own key, then update this value and redeploy.
VITE_DESMOS_API_KEY=dcb31709b452b1cf9dc26972add0fda6

# ── autodev mode (dev-only) ────────────────────────────────────────────────
# Skip the login screen while testing locally. Only runs in `npm run dev`; the
# whole code path is stripped from production builds, so these never ship.
# Set VITE_DEV_AUTOLOGIN=true and provide a LOCAL account's credentials, and
# leave VITE_API_BASE_URL unset so it authenticates against the local backend.
VITE_DEV_AUTOLOGIN=false
VITE_DEV_EMAIL=you@example.com
VITE_DEV_PASSWORD=
